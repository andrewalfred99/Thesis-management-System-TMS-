@page
@using TMS.Areas.Identity.Data
@inject SignInManager<PlatformUser> SignInManager
@inject UserManager<PlatformUser> UserManager
@model TMS.Pages.Theses.DetailsModel

@{
    ViewData["Title"] = "Thesis Details";
}

<h1>Thesis</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.Status)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.Semester)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.Semester)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.ExpectedHours)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.ExpectedHours)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.Year)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.Year)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.Faculty)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.Faculty.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Thesis.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Thesis.Name)
        </dd>
    </dl>
    <div class="row">
        <div class="col-md-8">
            <label asp-for="Thesis.Description" class="control-label" style="font-weight: bold"></label>
            <div id="ThesisDescription">
                @if (Model.Thesis != null)
                {
                    @Html.Raw(Model.Thesis.Description)
                }

            </div>
            <label asp-for="Thesis.Materials" class="control-label" style="font-weight: bold"></label>
            <div id="ThesisMaterials">
                @if (Model.Thesis != null)
                {
                    @Html.Raw(Model.Thesis.Materials)
                }

            </div>
        </div>
    </div>
    <h3>Languages</h3>
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Languages[0].Name)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Thesis.Languages)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <h3>Teachers</h3>
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Teachers[0].Name)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Thesis.Teachers)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-page="/Users/Edit" asp-route-id="@item.Id">Edit |</a>
                            <a asp-page="/Users/Details" asp-route-id="@item.Id">Details |</a>
                            <a asp-page="/Users/Delete" asp-route-id="@item.Id">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <h3>Students</h3>
    @if (User.IsInRole("Student") && Model.Thesis.Status == status.Open)
    {
        <form method="post">
            <div class="form-group">
                <input asp-page-handler="RequestAcc" type="submit" value="Request Access" class="btn btn-primary" />
                <input type="hidden" name="id" value="@Model.Thesis.Id" />
            </div>
        </form>
    }
    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Requests[0].Student.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Requests[0].Approved)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Requests)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Student.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Approved)
                    </td>
                    <td>
                        @if (item.Approved && Model.Thesis.Status == status.Open &&
                          User.IsInRole("Teacher") && Model.Thesis.Teachers.Contains(await UserManager.GetUserAsync(User)))
                        {
                            <form asp-page="/Grades/Create" method="post">
                                <div class="form-group">
                                    <input asp-page="/Grades/Create" asp-page-handler="AddGrade" type="submit" value="Add Grade" class="btn btn-primary" />
                                    <input type="hidden" name="ThesisId" value="@Model.Thesis.Id" />
                                    <input type="hidden" name="studentId" value="@item.Student.Id" />
                                </div>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <h3>Notifications</h3>
    @foreach (var item in Model.Notifications)
    {
        <div class="row">
            <div class="col-md-12">
                <div class="card">
                    <h5 class="card-header">@Html.DisplayFor(modelItem => item.Title)</h5>
                    <div class="card-body">
                        <p class="card-text">@Html.DisplayFor(modelItem => item.Description)</p>
                    </div>
                    <div class="card-footer text-muted">
                        @Html.DisplayFor(modelItem => item.DateTime)
                    </div>
                </div>
            </div>
        </div>
        <hr />
    }
</div>
<div>
    <input type="hidden" asp-for="Thesis.Name" />
    <input type="hidden" asp-for="Thesis.Year" />
    @if (User.IsInRole("Admin"))
    {
        <a asp-page="./Edit" asp-route-id="@Model.Thesis.Id">Edit |</a>
        <a asp-page="./Index">Back to List</a>
    }
    else if (User.IsInRole("Teacher"))
    {
        <a asp-page="./Edit" asp-route-id="@Model.Thesis.Id">Edit |</a>
        <a asp-page="/Index">Back to Home</a>
    }
    else
    {
        <a asp-page="/Index">Back to Home</a>
    }

</div>
